{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pages/layout,_N_T_/pages/dashboard/layout,_N_T_/pages/dashboard/page,_N_T_/pages/dashboard"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pages/dashboard/__PAGE__",
    "/pages/dashboard",
    "/pages",
    "/_index",
    "/_head"
  ]
}